{
  "name": "frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:employee": "vite --config vite.config.employee.ts",
    "dev:admin": "vite --config vite.config.admin.ts",
    "dev:all": "npm-run-all --parallel dev:employee dev:admin",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:employee": "vite build --config vite.config.employee.ts",
    "build:admin": "vite build --config vite.config.admin.ts",
    "preview": "vite preview",
    "type-check": "vue-tsc --build"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@tanstack/vue-table": "^8.21.3",
    "@types/leaflet": "^1.9.21",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.15.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.6",
    "shadcn-vue": "^2.6.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.5.0",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.13",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.0",
    "vite": "^8.0.8",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
